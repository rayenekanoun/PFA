# Backend environment
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/car_diagnostics?schema=public
REDIS_URL=redis://localhost:6379/0
JWT_ACCESS_SECRET=replace-with-a-long-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
MQTT_SERVERS=localhost:1883,localhost:2883,localhost:3883
MQTT_CLIENT_ID=diagnostic-backend
MQTT_REQUEST_TIMEOUT_MS=15000
SUPPORTED_PID_STALE_HOURS=24
SWAGGER_ENABLED=true
DEV_DISABLE_OWNERSHIP_FILTER=false
CORS_ORIGIN=http://localhost:5173
AI_PROVIDER=stub
AI_ALLOW_STUB_FALLBACK=false
AI_API_KEY=
AI_MODEL=gpt-4.1-mini
AI_BASE_URL=https://api.openai.com/v1
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash
VERTEX_SERVICE_ACCOUNT_JSON=
VERTEX_SERVICE_ACCOUNT_PATH=
VERTEX_SERVICE_ACCOUNT_PATH_DOCKER=
GOOGLE_APPLICATION_CREDENTIALS=

# Gemini example:
# AI_PROVIDER=gemini
# AI_API_KEY=your_google_ai_key
# AI_MODEL=gemini-1.5-flash
# AI_BASE_URL=https://generativelanguage.googleapis.com

# Vertex AI example (service account file):
# AI_PROVIDER=vertex
# VERTEX_PROJECT_ID=your-gcp-project-id
# VERTEX_LOCATION=us-central1
# VERTEX_MODEL=gemini-2.5-flash
# VERTEX_SERVICE_ACCOUNT_PATH=C:\path\to\service-account.json
# VERTEX_SERVICE_ACCOUNT_PATH_DOCKER=/run/secrets/service-account.json
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# Vertex AI example (inline JSON in env; avoid committing secrets):
# AI_PROVIDER=vertex
# VERTEX_PROJECT_ID=your-gcp-project-id
# VERTEX_MODEL=gemini-2.5-flash
# VERTEX_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n..."}
