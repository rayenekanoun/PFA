generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
}

enum DeviceStatus {
  AVAILABLE
  LINKED
  OFFLINE
  ERROR
  DISABLED
}

enum ConversationMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ConversationMessageKind {
  INITIAL_PROMPT
  REPORT
  FOLLOW_UP_QUESTION
  FOLLOW_UP_ANSWER
  SYSTEM_NOTE
}

enum DiagnosticRequestStatus {
  CREATED
  DISCOVERING_CAPABILITIES
  PLANNED
  QUEUED
  DISPATCHED
  RUNNING
  GENERATING_REPORT
  COMPLETED
  FAILED
}

enum DiagnosticRunStatus {
  QUEUED
  SENT
  RESPONDED
  TIMEOUT
  PARTIAL
  FAILED
}

enum MeasurementStatus {
  OK
  UNSUPPORTED
  TIMEOUT
  ERROR
  MISSING
}

enum ValueType {
  NUMBER
  STRING
  BOOLEAN
  JSON
}

enum DtcState {
  STORED
  PENDING
  PERMANENT
}

model User {
  id            String              @id @default(uuid())
  email         String              @unique
  passwordHash  String
  displayName   String
  role          UserRole            @default(USER)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  refreshTokens RefreshToken[]
  vehicles      Vehicle[]
  requests      DiagnosticRequest[]
  conversations DiagnosticConversation[]
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Vehicle {
  id                    String                @id @default(uuid())
  userId                String
  mqttCarId             String                @unique
  vin                   String?               @unique
  make                  String?
  model                 String?
  year                  Int?
  status                VehicleStatus         @default(ACTIVE)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  device                Device?
  supportedPids         VehicleSupportedPid[]
  diagnosticRequests    DiagnosticRequest[]
  conversations         DiagnosticConversation[]

  @@index([userId])
}

model Device {
  id                        String          @id @default(uuid())
  deviceCode                String          @unique
  serialNumber              String?         @unique
  firmwareVersion           String?
  vehicleId                 String?         @unique
  status                    DeviceStatus    @default(AVAILABLE)
  capabilitiesDiscoveredAt  DateTime?
  capabilitiesResponseJson  Json?
  lastSeenAt                DateTime?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt
  vehicle                   Vehicle?        @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  diagnosticRuns            DiagnosticRun[]

  @@index([status])
}

model DiagnosticProfile {
  id                      String               @id @default(uuid())
  code                    String               @unique
  name                    String
  description             String?
  defaultRequestedPidsJson Json
  includeDtcsByDefault    Boolean              @default(true)
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  diagnosticRequests      DiagnosticRequest[]
  diagnosticPlans         DiagnosticPlan[]
}

model ObdPidCatalog {
  id                  String                @id @default(uuid())
  mode                String
  pidCode             String
  fullCode            String                @unique
  key                 String                @unique
  label               String
  unit                String?
  valueType           ValueType
  description         String?
  formula             String?
  isMandatory         Boolean               @default(false)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  supportedVehicles   VehicleSupportedPid[]
  measurements        DiagnosticMeasurement[]

  @@unique([mode, pidCode])
}

model VehicleSupportedPid {
  id             String        @id @default(uuid())
  vehicleId      String
  pidCatalogId   String
  isSupported    Boolean
  checkedAt      DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  vehicle        Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  pidCatalog     ObdPidCatalog @relation(fields: [pidCatalogId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, pidCatalogId])
  @@index([vehicleId])
}

model DiagnosticRequest {
  id                        String                  @id @default(uuid())
  userId                    String
  vehicleId                 String
  complaintText             String
  debugConfigJson           Json?
  classifiedProfileId       String?
  classificationConfidence  Float?
  classificationRationale   String?
  status                    DiagnosticRequestStatus @default(CREATED)
  errorMessage              String?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  completedAt               DateTime?
  user                      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle                   Vehicle                 @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  classifiedProfile         DiagnosticProfile?      @relation(fields: [classifiedProfileId], references: [id], onDelete: SetNull)
  plan                      DiagnosticPlan?
  report                    DiagnosticReport?
  conversation              DiagnosticConversation?

  @@index([userId])
  @@index([vehicleId])
}

model DiagnosticPlan {
  id                  String             @id @default(uuid())
  diagnosticRequestId String             @unique
  profileId           String?
  requestedPidsJson   Json
  includeDtcs         Boolean            @default(false)
  plannerNotes        String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  diagnosticRequest   DiagnosticRequest  @relation(fields: [diagnosticRequestId], references: [id], onDelete: Cascade)
  profile             DiagnosticProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  runs                DiagnosticRun[]
}

model DiagnosticRun {
  id                String              @id @default(uuid())
  diagnosticPlanId  String
  deviceId          String?
  mqttJobId         String?             @unique
  status            DiagnosticRunStatus @default(QUEUED)
  mqttCommandJson   Json?
  rawResponseJson   Json?
  errorMessage      String?
  startedAt         DateTime?
  respondedAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  diagnosticPlan    DiagnosticPlan      @relation(fields: [diagnosticPlanId], references: [id], onDelete: Cascade)
  device            Device?             @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  measurements      DiagnosticMeasurement[]
  dtcs              DiagnosticDtc[]
  report            DiagnosticReport?

  @@index([diagnosticPlanId])
}

model DiagnosticMeasurement {
  id             String            @default(uuid())
  diagnosticRunId String
  pidCatalogId   String?
  measurementKey String
  label          String
  valueNumber    Float?
  valueText      String?
  valueBoolean   Boolean?
  valueJson      Json?
  unit           String?
  status         MeasurementStatus @default(OK)
  rawValue       String?
  measuredAt     DateTime          @default(now())
  createdAt      DateTime          @default(now())
  diagnosticRun  DiagnosticRun     @relation(fields: [diagnosticRunId], references: [id], onDelete: Cascade)
  pidCatalog     ObdPidCatalog?    @relation(fields: [pidCatalogId], references: [id], onDelete: SetNull)

  @@id([id, measuredAt])
  @@index([diagnosticRunId])
  @@index([measurementKey])
  @@index([measuredAt])
}

model DiagnosticDtc {
  id              String    @id @default(uuid())
  diagnosticRunId String
  code            String
  description     String
  severity        String?
  state           DtcState
  sourceMode      String?
  createdAt       DateTime  @default(now())
  diagnosticRun   DiagnosticRun @relation(fields: [diagnosticRunId], references: [id], onDelete: Cascade)

  @@index([diagnosticRunId])
  @@index([code])
}

model DiagnosticReport {
  id                    String            @id @default(uuid())
  diagnosticRequestId   String            @unique
  diagnosticRunId       String            @unique
  structuredSummaryJson Json
  reportJson            Json
  reportText            String
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  diagnosticRequest     DiagnosticRequest @relation(fields: [diagnosticRequestId], references: [id], onDelete: Cascade)
  diagnosticRun         DiagnosticRun     @relation(fields: [diagnosticRunId], references: [id], onDelete: Cascade)
}

model DiagnosticConversation {
  id                  String                    @id @default(uuid())
  diagnosticRequestId String                    @unique
  userId              String
  vehicleId           String
  title               String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  diagnosticRequest   DiagnosticRequest         @relation(fields: [diagnosticRequestId], references: [id], onDelete: Cascade)
  user                User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle             Vehicle                   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  messages            DiagnosticConversationMessage[]

  @@index([userId])
  @@index([vehicleId])
}

model DiagnosticConversationMessage {
  id              String                  @id @default(uuid())
  conversationId  String
  role            ConversationMessageRole
  kind            ConversationMessageKind
  content         String
  metadataJson    Json?
  createdAt       DateTime                @default(now())
  conversation    DiagnosticConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}
