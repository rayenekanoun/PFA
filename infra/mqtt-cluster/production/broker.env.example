# Unique per broker VPS
EMQX_HOSTNAME=broker-1.your-domain.com
EMQX_NODE_NAME=emqx@broker-1.your-domain.com

# Must be identical on all brokers
EMQX_NODE_COOKIE=change_me_cluster_cookie
EMQX_CLUSTER_STATIC_SEEDS=[emqx@broker-1.your-domain.com,emqx@broker-2.your-domain.com,emqx@broker-3.your-domain.com]

# Dashboard credentials
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASS=change_me_strong_password

# Ports
EMQX_MQTT_PORT=1883
EMQX_DASHBOARD_PORT=18083
EMQX_CLUSTER_EPMP_PORT=4370
EMQX_CLUSTER_RPC_PORT=5369
